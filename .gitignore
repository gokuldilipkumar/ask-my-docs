# Source corpus (large, publicly downloadable — document the download step instead of committing it)
*.pdf

# Ingestion artifacts (regenerable from the PDF) except the built index,
# which CI needs and is small enough (~2-7MB) to commit directly.
data/*
!data/index/
!data/index/**
*.index

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Secrets
.env
.env.local

# Local machine settings
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
